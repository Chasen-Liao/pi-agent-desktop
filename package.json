{
  "name": "@chasen-liao/pi-agent-desktop",
  "version": "0.7.16",
  "description": "Pi Agent Desktop — desktop client for the pi coding agent",
  "license": "MIT",
  "author": "Chasen",
  "main": "electron/dist/main.js",
  "bin": {
    "pi-web": "bin/pi-web.js"
  },
  "files": [
    "bin",
    ".next",
    "!.next/cache",
    "!.next/dev",
    "!.next/**/*.js.map",
    "public",
    "next.config.ts",
    "package.json"
  ],
  "scripts": {
    "dev": "next dev -p 30141",
    "build": "npm run build:standalone",
    "build:standalone": "next build",
    "start": "next start -p 30141",
    "lint": "eslint .",
    "test": "node --test --test-force-exit \"lib/**/*.test.ts\" \"lib/**/*.test.mjs\" \"electron/**/*.test.ts\" \"app/**/*.test.ts\" \"hooks/**/*.test.ts\" \"components/**/*.test.ts\" \"package.test.ts\"",
    "release": "npm version patch --no-git-tag-version && npm run build:standalone && npm publish --access public",
    "build:electron": "tsc -p electron/tsconfig.json && node -e \"const fs=require('fs'); fs.copyFileSync('electron/startup.html', 'electron/dist/startup.html'); fs.copyFileSync('electron/startup.js', 'electron/dist/startup.js')\"",
    "dev:electron": "npm run build:electron && npx electron .",
    "pack": "npm run build:standalone && npm run build:electron && npx @electron/rebuild && npx electron-builder --dir",
    "dist": "npm run build:standalone && npm run build:electron && npx @electron/rebuild && npx electron-builder"
  },
  "build": {
    "extends": "electron-builder.yml"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.79.8",
    "@earendil-works/pi-coding-agent": "^0.79.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@lobehub/icons": "^5.6.0",
    "next": "16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "@electron/packager": "^20.0.0",
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "electron": "^36.9.5",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "postcss": "^8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5"
  },
  "allowScripts": {
    "electron@36.9.5": true
  }
}
